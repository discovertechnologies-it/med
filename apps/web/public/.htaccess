# .htaccess — Med web app (Apache 2.4+)
# Vite copies this from public/ to dist/ during build.
# Tested on cPanel / Hostinger / shared LAMP hosts.

# =====================================================================
# 1. Force HTTPS (skip on localhost so dev still works)
# =====================================================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !=https
  RewriteCond %{HTTP_HOST} !^localhost [NC]
  RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# =====================================================================
# 2. SPA fallback — route all non-asset paths to index.html
#    React Router handles deep links like /cart, /orders/123, /legal/privacy
# =====================================================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the request is for a real file or directory, serve it as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Never rewrite the service worker, manifest, or root assets
  RewriteRule ^(sw\.js|workbox-.*\.js|manifest\.webmanifest|icon.*\.svg|robots\.txt|sitemap\.xml|favicon\.ico|\.well-known/.*)$ - [L]

  # Send everything else to the SPA shell
  RewriteRule ^ index.html [L]
</IfModule>

# =====================================================================
# 3. Compression
# =====================================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE application/manifest+json application/ld+json
  AddOutputFilterByType DEFLATE image/svg+xml font/woff2 font/woff
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType BROTLI_COMPRESS application/javascript application/json application/xml
  AddOutputFilterByType BROTLI_COMPRESS application/manifest+json application/ld+json
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml font/woff2 font/woff
</IfModule>

# =====================================================================
# 4. Cache headers
#    - Hashed assets (Vite content hashes) → immutable for 1 year
#    - index.html / sw.js / manifest → no-cache so updates ship instantly
# =====================================================================
<IfModule mod_headers.c>
  # Hashed build assets in /assets/ — fingerprinted, safe to cache forever
  <FilesMatch "\.(js|mjs|css|woff2|woff)$">
    <If "%{REQUEST_URI} =~ m#^/assets/#">
      Header set Cache-Control "public, max-age=31536000, immutable"
    </If>
  </FilesMatch>

  # SPA shell + service worker + manifest must always revalidate
  <FilesMatch "^(index\.html|sw\.js|workbox-.*\.js|manifest\.webmanifest)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # PWA icons — moderate cache (30 days)
  <FilesMatch "^icon.*\.svg$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # robots / sitemap — short cache
  <FilesMatch "^(robots\.txt|sitemap\.xml)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>

# Fallback for hosts without mod_headers
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                "access plus 0 seconds"
  ExpiresByType application/manifest+json "access plus 0 seconds"
  ExpiresByType text/css                 "access plus 1 year"
  ExpiresByType application/javascript   "access plus 1 year"
  ExpiresByType font/woff2               "access plus 1 year"
  ExpiresByType font/woff                "access plus 1 year"
  ExpiresByType image/svg+xml            "access plus 30 days"
  ExpiresByType image/png                "access plus 30 days"
  ExpiresByType image/x-icon             "access plus 30 days"
</IfModule>

# =====================================================================
# 5. MIME types — ensure PWA assets serve with correct content-type
# =====================================================================
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType application/javascript    .js .mjs
  AddType font/woff2                .woff2
  AddType font/woff                 .woff
  AddType image/svg+xml             .svg
  AddType application/wasm          .wasm
</IfModule>

# =====================================================================
# 6. Security headers
# =====================================================================
<IfModule mod_headers.c>
  # HSTS — force HTTPS at browser level (1 year). Only enable after you have HTTPS working.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Block embedding in other sites (modern equivalent of X-Frame-Options: DENY)
  Header always set X-Frame-Options "DENY"

  # Stop MIME sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Limit data sent to other origins
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Disable powerful APIs we do not use; allow geolocation + payment + camera (prescription upload)
  Header always set Permissions-Policy "camera=(self), microphone=(), geolocation=(self), payment=(self), usb=(), accelerometer=(), gyroscope=(), interest-cohort=()"

  # Cross-origin isolation — relax if you need to embed third-party iframes/widgets
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"

  # Content Security Policy
  # Notes:
  #  - 'unsafe-inline' on style-src is required because Framer Motion sets inline style attributes
  #  - When backend lands, append the API origin to connect-src (e.g. https://api.med.example)
  #  - Razorpay/payment gateways will need allowances added (script-src + frame-src)
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; form-action 'self'; base-uri 'self'; manifest-src 'self'; worker-src 'self'; object-src 'none'; upgrade-insecure-requests"

  # Service worker is allowed to control the entire origin
  <FilesMatch "^sw\.js$">
    Header always set Service-Worker-Allowed "/"
    Header always set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# =====================================================================
# 7. Drop ETag — we rely on Cache-Control + content hashing
# =====================================================================
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None

# =====================================================================
# 8. Hide sensitive files
# =====================================================================
Options -Indexes

<FilesMatch "(^\.|\.bak$|\.swp$|\.log$|composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|\.env|\.git)">
  Require all denied
</FilesMatch>

# Block dotfiles, but allow .well-known (for SSL, ACME, etc.)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_URI} !^/\.well-known/
  RewriteRule "(^|/)\." - [F]
</IfModule>

# =====================================================================
# 9. Default charset
# =====================================================================
AddDefaultCharset UTF-8
